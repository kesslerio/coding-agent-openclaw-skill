#!/usr/bin/env bash
# review-loop-supervisor - supervise codex review/fix iterations until P0-P2 clear
set -euo pipefail

export PATH="$PATH:/run/current-system/sw/bin"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/canonical-repo-guard.sh"
ensure_canonical_repo_from_script_dir "$SCRIPT_DIR"

usage() {
  cat >&2 <<'USAGE'
Usage:
  review-loop-supervisor [options]

Options:
  --repo <path>                     Repository path (default: current directory)
  --base <branch>                   Base branch for codex review (default: auto-detect)
  --test-cmd <command>              Test command to run (repeatable)
  --closure-mode <local|github>     Completion rule (default: local)
  --github-review-author <login>    Require a GitHub review from this login (repeatable)
  --github-review-wait-seconds <s>  Max wait for GitHub-visible review closure (default: 180)
  --github-review-poll-seconds <s>  Poll interval while waiting on GitHub review (default: 15)
  --review-timeout <seconds>        Timeout for codex review (default: 900, min: 600)
  --fix-timeout <seconds>           Timeout for codex fix exec (default: 900)
  --max-runtime-seconds <seconds>   Total runtime budget (default: 5400)
  --status-interval-seconds <sec>   Heartbeat interval (default: 120)
  --open-pr                         Commit/push and create-or-update PR when ready
  --issue <number>                  Issue number to reference in PR body
  --commit-msg <text>               Commit message override when creating commit
  --pr-title <text>                 PR title override
  --pr-body <text>                  PR body override
  --pr-body-file <path>             PR body file override
  -h, --help                        Show help
USAGE
}

emit_run_event() {
  local event="$1"
  local details="${2:-}"
  if [[ -n "$details" ]]; then
    echo "RUN_EVENT $event ts=$(date -Iseconds) $details" >&2
  else
    echo "RUN_EVENT $event ts=$(date -Iseconds)" >&2
  fi
}

json_escape() {
  python3 - <<'PY' "$1"
import json
import sys
print(json.dumps(sys.argv[1]))
PY
}

emit_supervisor_event() {
  local type="$1"
  local payload="${2:-{}}"
  printf 'SUPERVISOR_EVENT {"ts":%s,"type":%s,"payload":%s}\n' \
    "$(json_escape "$(date -Iseconds)")" \
    "$(json_escape "$type")" \
    "$payload" >&2
}

ensure_number() {
  local name="$1"
  local value="$2"
  if [[ ! "$value" =~ ^[0-9]+$ ]]; then
    echo "Error: $name must be a non-negative integer (got '$value')." >&2
    exit 1
  fi
}

derive_base_branch() {
  if [[ -n "${BASE_BRANCH:-}" ]]; then
    printf '%s\n' "$BASE_BRANCH"
    return 0
  fi

  local detected=""
  detected="$(git -C "$REPO_PATH" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')"
  if [[ -n "$detected" ]]; then
    printf '%s\n' "$detected"
    return 0
  fi

  for candidate in main master trunk; do
    if git -C "$REPO_PATH" show-ref --verify --quiet "refs/remotes/origin/${candidate}" || \
       git -C "$REPO_PATH" show-ref --verify --quiet "refs/heads/${candidate}"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'main\n'
}

ensure_tooling() {
  local missing=()
  local required=(codex timeout git python3)
  if (( OPEN_PR == 1 )) || [[ "$CLOSURE_MODE" == "github" ]]; then
    required+=(gh)
  fi
  local bin
  for bin in "${required[@]}"; do
    if ! command -v "$bin" >/dev/null 2>&1; then
      missing+=("$bin")
    fi
  done
  if (( ${#missing[@]} > 0 )); then
    echo "Error: missing required tools: ${missing[*]}" >&2
    exit 1
  fi
  if [[ ! -x "$SAFE_REVIEW_BIN" ]]; then
    echo "Error: review wrapper is missing or not executable: $SAFE_REVIEW_BIN" >&2
    exit 1
  fi
}

handle_supervisor_signal() {
  local signal="$1"
  local exit_code="130"
  if [[ "$signal" == "TERM" ]]; then
    exit_code="143"
  fi

  write_state "interrupted" "signal_${signal}"
  emit_supervisor_event "terminal" "{\"state\":\"interrupted\",\"reason\":\"signal_${signal}\",\"iteration\":${ITERATION}}"
  emit_run_event "interrupted" "phase=review-loop-supervisor state=${CURRENT_STATE} iteration=${ITERATION} signal=${signal} exit_code=${exit_code}"
  exit "$exit_code"
}

match_last_line() {
  local pattern="$1"
  local file="$2"
  if command -v rg >/dev/null 2>&1; then
    rg "$pattern" "$file" | tail -n 1 || true
  else
    grep -E -- "$pattern" "$file" | tail -n 1 || true
  fi
}

check_runtime_budget() {
  local now elapsed
  now="$(date +%s)"
  elapsed=$(( now - START_TS ))
  if (( elapsed >= MAX_RUNTIME_SECONDS )); then
    write_state "timed_out" "runtime_budget_exceeded"
    emit_supervisor_event "terminal" "{\"state\":\"timed_out\",\"reason\":\"runtime_budget_exceeded\",\"elapsed_seconds\":${elapsed}}"
    emit_run_event "failed" "phase=review-loop-supervisor reason=runtime_budget_exceeded elapsed=${elapsed}s"
    exit 1
  fi
}

maybe_heartbeat() {
  local phase="$1"
  local now elapsed since
  now="$(date +%s)"
  elapsed=$(( now - START_TS ))
  since=$(( now - LAST_STATUS_TS ))
  if (( since >= STATUS_INTERVAL_SECONDS )); then
    emit_run_event "heartbeat" "phase=review-loop-supervisor state=${CURRENT_STATE} iteration=${ITERATION} elapsed=${elapsed}s current_phase=${phase}"
    LAST_STATUS_TS="$now"
  fi
}

state_dir_path() {
  printf '%s/.ai/review-loops\n' "$REPO_PATH"
}

refresh_head_state() {
  HEAD_BRANCH="$(git -C "$REPO_PATH" branch --show-current)"
  if [[ -z "$HEAD_BRANCH" ]]; then
    echo "Error: unable to determine current branch in $REPO_PATH" >&2
    exit 1
  fi
  HEAD_SHA="$(git -C "$REPO_PATH" rev-parse HEAD)"
}

repo_status_filtered() {
  git -C "$REPO_PATH" status --porcelain --untracked-files=all -- . ':(exclude).ai/review-loops/**'
}

write_state() {
  local state="$1"
  local reason="$2"

  local now_iso elapsed dirty pr_url_json last_review_exit_code_json
  local last_review_command_json last_review_artifact_json
  local github_review_url_json github_review_author_json github_review_submitted_at_json
  now_iso="$(date -Iseconds)"
  elapsed=$(( $(date +%s) - START_TS ))
  dirty="false"
  if [[ -n "$(repo_status_filtered)" ]]; then
    dirty="true"
  fi

  if [[ -n "$PR_URL" ]]; then
    pr_url_json="$(json_escape "$PR_URL")"
  else
    pr_url_json="null"
  fi

  if [[ -n "$LAST_REVIEW_EXIT_CODE" ]]; then
    last_review_exit_code_json="$LAST_REVIEW_EXIT_CODE"
  else
    last_review_exit_code_json="null"
  fi

  if [[ -n "$LAST_REVIEW_COMMAND" ]]; then
    last_review_command_json="$(json_escape "$LAST_REVIEW_COMMAND")"
  else
    last_review_command_json="null"
  fi

  if [[ -n "$LAST_REVIEW_ARTIFACT" ]]; then
    last_review_artifact_json="$(json_escape "$LAST_REVIEW_ARTIFACT")"
  else
    last_review_artifact_json="null"
  fi

  if [[ -n "$GITHUB_REVIEW_URL" ]]; then
    github_review_url_json="$(json_escape "$GITHUB_REVIEW_URL")"
  else
    github_review_url_json="null"
  fi

  if [[ -n "$GITHUB_REVIEW_AUTHOR" ]]; then
    github_review_author_json="$(json_escape "$GITHUB_REVIEW_AUTHOR")"
  else
    github_review_author_json="null"
  fi

  if [[ -n "$GITHUB_REVIEW_SUBMITTED_AT" ]]; then
    github_review_submitted_at_json="$(json_escape "$GITHUB_REVIEW_SUBMITTED_AT")"
  else
    github_review_submitted_at_json="null"
  fi

  cat > "$STATE_HISTORY_FILE" <<EOFSTATE
{
  "schema_version": 1,
  "state": "${state}",
  "reason": "${reason}",
  "repo_path": "${REPO_PATH}",
  "base_branch": "${BASE_BRANCH}",
  "head_branch": "${HEAD_BRANCH}",
  "head_sha": "${HEAD_SHA}",
  "open_pr": ${OPEN_PR},
  "closure_mode": "${CLOSURE_MODE}",
  "issue": ${ISSUE_NUMBER_JSON},
  "current_iteration": ${ITERATION},
  "elapsed_seconds": ${elapsed},
  "counts": {
    "P0": ${COUNT_P0},
    "P1": ${COUNT_P1},
    "P2": ${COUNT_P2},
    "P3": ${COUNT_P3}
  },
  "deltas": {
    "P0": ${DELTA_P0},
    "P1": ${DELTA_P1},
    "P2": ${DELTA_P2},
    "P3": ${DELTA_P3}
  },
  "top_findings": {
    "P0": {"location": $(json_escape "$TOP_P0_LOCATION"), "issue": $(json_escape "$TOP_P0_ISSUE"), "planned_patch": $(json_escape "$TOP_P0_PATCH")},
    "P1": {"location": $(json_escape "$TOP_P1_LOCATION"), "issue": $(json_escape "$TOP_P1_ISSUE"), "planned_patch": $(json_escape "$TOP_P1_PATCH")},
    "P2": {"location": $(json_escape "$TOP_P2_LOCATION"), "issue": $(json_escape "$TOP_P2_ISSUE"), "planned_patch": $(json_escape "$TOP_P2_PATCH")},
    "P3": {"location": $(json_escape "$TOP_P3_LOCATION"), "issue": $(json_escape "$TOP_P3_ISSUE"), "planned_patch": $(json_escape "$TOP_P3_PATCH")}
  },
  "pr_url": ${pr_url_json},
  "worktree_dirty": ${dirty},
  "last_review_output": $(json_escape "$LAST_REVIEW_OUTPUT"),
  "last_review_exit_code": ${last_review_exit_code_json},
  "last_review_command": ${last_review_command_json},
  "last_review_artifact": ${last_review_artifact_json},
  "last_fix_output": $(json_escape "$LAST_FIX_OUTPUT"),
  "github_review": {
    "status": "${GITHUB_REVIEW_STATUS}",
    "url": ${github_review_url_json},
    "author": ${github_review_author_json},
    "submitted_at": ${github_review_submitted_at_json}
  },
  "updated_at": "${now_iso}"
}
EOFSTATE

  cp "$STATE_HISTORY_FILE" "$STATE_LATEST_FILE"
}

review_prompt_base() {
  cat <<'PROMPT'
Run a strict findings-first review with severity buckets P0-P3 for this repository against the base branch.
Keep core findings concise, include file:line references, and include realistic planned patch guidance for top findings.

At the very end of your response, output ONLY these exact machine lines (one per line):
SUPERVISOR_COUNTS P0=<n> P1=<n> P2=<n> P3=<n>
SUPERVISOR_TOP P0|<file:line or none>|<issue summary or none>|<planned patch summary or none>
SUPERVISOR_TOP P1|<file:line or none>|<issue summary or none>|<planned patch summary or none>
SUPERVISOR_TOP P2|<file:line or none>|<issue summary or none>|<planned patch summary or none>
SUPERVISOR_TOP P3|<file:line or none>|<issue summary or none>|<planned patch summary or none>
PROMPT
}

parse_review_footer() {
  local file="$1"
  local counts_line
  local top_p0 top_p1 top_p2 top_p3

  counts_line="$(match_last_line '^SUPERVISOR_COUNTS P0=[0-9]+ P1=[0-9]+ P2=[0-9]+ P3=[0-9]+$' "$file")"
  top_p0="$(match_last_line '^SUPERVISOR_TOP P0\|[^|]+\|[^|]+\|.+$' "$file")"
  top_p1="$(match_last_line '^SUPERVISOR_TOP P1\|[^|]+\|[^|]+\|.+$' "$file")"
  top_p2="$(match_last_line '^SUPERVISOR_TOP P2\|[^|]+\|[^|]+\|.+$' "$file")"
  top_p3="$(match_last_line '^SUPERVISOR_TOP P3\|[^|]+\|[^|]+\|.+$' "$file")"

  if [[ -z "$counts_line" || -z "$top_p0" || -z "$top_p1" || -z "$top_p2" || -z "$top_p3" ]]; then
    return 1
  fi

  COUNT_P0="$(sed -nE 's/^SUPERVISOR_COUNTS P0=([0-9]+) P1=([0-9]+) P2=([0-9]+) P3=([0-9]+)$/\1/p' <<<"$counts_line")"
  COUNT_P1="$(sed -nE 's/^SUPERVISOR_COUNTS P0=([0-9]+) P1=([0-9]+) P2=([0-9]+) P3=([0-9]+)$/\2/p' <<<"$counts_line")"
  COUNT_P2="$(sed -nE 's/^SUPERVISOR_COUNTS P0=([0-9]+) P1=([0-9]+) P2=([0-9]+) P3=([0-9]+)$/\3/p' <<<"$counts_line")"
  COUNT_P3="$(sed -nE 's/^SUPERVISOR_COUNTS P0=([0-9]+) P1=([0-9]+) P2=([0-9]+) P3=([0-9]+)$/\4/p' <<<"$counts_line")"

  parse_top_line "P0" "$top_p0"
  parse_top_line "P1" "$top_p1"
  parse_top_line "P2" "$top_p2"
  parse_top_line "P3" "$top_p3"

  return 0
}

parse_top_line() {
  local level="$1"
  local line="$2"
  local payload location issue patch

  payload="${line#SUPERVISOR_TOP "${level}"|}"
  location="${payload%%|*}"
  payload="${payload#*|}"
  issue="${payload%%|*}"
  patch="${payload#*|}"

  case "$level" in
    P0)
      TOP_P0_LOCATION="$location"
      TOP_P0_ISSUE="$issue"
      TOP_P0_PATCH="$patch"
      ;;
    P1)
      TOP_P1_LOCATION="$location"
      TOP_P1_ISSUE="$issue"
      TOP_P1_PATCH="$patch"
      ;;
    P2)
      TOP_P2_LOCATION="$location"
      TOP_P2_ISSUE="$issue"
      TOP_P2_PATCH="$patch"
      ;;
    P3)
      TOP_P3_LOCATION="$location"
      TOP_P3_ISSUE="$issue"
      TOP_P3_PATCH="$patch"
      ;;
  esac
}

emit_delta_and_state_change_events() {
  DELTA_P0=$(( COUNT_P0 - PREV_P0 ))
  DELTA_P1=$(( COUNT_P1 - PREV_P1 ))
  DELTA_P2=$(( COUNT_P2 - PREV_P2 ))
  DELTA_P3=$(( COUNT_P3 - PREV_P3 ))

  emit_supervisor_event "counts" "{\"iteration\":${ITERATION},\"counts\":{\"P0\":${COUNT_P0},\"P1\":${COUNT_P1},\"P2\":${COUNT_P2},\"P3\":${COUNT_P3}},\"deltas\":{\"P0\":${DELTA_P0},\"P1\":${DELTA_P1},\"P2\":${DELTA_P2},\"P3\":${DELTA_P3}}}"

  if (( DELTA_P0 > 0 )); then
    emit_supervisor_event "state_change" "{\"iteration\":${ITERATION},\"severity\":\"P0\",\"delta\":${DELTA_P0},\"location\":$(json_escape "$TOP_P0_LOCATION"),\"planned_patch\":$(json_escape "$TOP_P0_PATCH")}"
  fi
  if (( DELTA_P1 > 0 )); then
    emit_supervisor_event "state_change" "{\"iteration\":${ITERATION},\"severity\":\"P1\",\"delta\":${DELTA_P1},\"location\":$(json_escape "$TOP_P1_LOCATION"),\"planned_patch\":$(json_escape "$TOP_P1_PATCH")}"
  fi
  if (( DELTA_P2 > 0 )); then
    emit_supervisor_event "state_change" "{\"iteration\":${ITERATION},\"severity\":\"P2\",\"delta\":${DELTA_P2},\"location\":$(json_escape "$TOP_P2_LOCATION"),\"planned_patch\":$(json_escape "$TOP_P2_PATCH")}"
  fi
  if (( DELTA_P3 > 0 )); then
    emit_supervisor_event "state_change" "{\"iteration\":${ITERATION},\"severity\":\"P3\",\"delta\":${DELTA_P3},\"location\":$(json_escape "$TOP_P3_LOCATION"),\"planned_patch\":$(json_escape "$TOP_P3_PATCH")}"
  fi

  PREV_P0="$COUNT_P0"
  PREV_P1="$COUNT_P1"
  PREV_P2="$COUNT_P2"
  PREV_P3="$COUNT_P3"
}

run_tests() {
  local phase="$1"
  if (( ${#TEST_COMMANDS[@]} == 0 )); then
    emit_supervisor_event "tests_skipped" "{\"phase\":$(json_escape "$phase"),\"reason\":\"no_test_commands\"}"
    return 0
  fi

  emit_supervisor_event "tests_started" "{\"phase\":$(json_escape "$phase"),\"count\":${#TEST_COMMANDS[@]}}"
  local cmd
  for cmd in "${TEST_COMMANDS[@]}"; do
    maybe_heartbeat "tests"
    if ! timeout "${REVIEW_TIMEOUT}s" bash -lc "cd \"$REPO_PATH\" && $cmd"; then
      emit_supervisor_event "tests_failed" "{\"phase\":$(json_escape "$phase"),\"command\":$(json_escape "$cmd") }"
      write_state "failed" "test_command_failed"
      emit_run_event "failed" "phase=review-loop-supervisor reason=test_command_failed iteration=${ITERATION}"
      exit 1
    fi
  done
  emit_supervisor_event "tests_completed" "{\"phase\":$(json_escape "$phase"),\"count\":${#TEST_COMMANDS[@]}}"
}

build_review_title() {
  printf 'PR Review\n'
}

build_review_command_summary() {
  local title="$1"
  printf 'TIMEOUT=%s %s codex review --base %s --title %s [prompt omitted]\n' \
    "$REVIEW_TIMEOUT" \
    "$SAFE_REVIEW_BIN" \
    "$BASE_BRANCH" \
    "$title"
}

persist_terminal_review_artifact() {
  local attempt="$1"
  local artifact_path

  artifact_path="$(state_dir_path)/${RUN_TS}-${HEAD_BRANCH//\//-}-review-iter-${ITERATION}-attempt-${attempt}.txt"
  cp "$LAST_REVIEW_OUTPUT" "$artifact_path"
  LAST_REVIEW_ARTIFACT="$artifact_path"
}

build_review_failure_payload() {
  local attempt="$1"
  local reason="$2"
  local output_json artifact_json exit_code_json command_json

  output_json="$(json_escape "$LAST_REVIEW_OUTPUT")"
  if [[ -n "$LAST_REVIEW_ARTIFACT" ]]; then
    artifact_json="$(json_escape "$LAST_REVIEW_ARTIFACT")"
  else
    artifact_json="null"
  fi
  if [[ -n "$LAST_REVIEW_EXIT_CODE" ]]; then
    exit_code_json="$LAST_REVIEW_EXIT_CODE"
  else
    exit_code_json="null"
  fi
  if [[ -n "$LAST_REVIEW_COMMAND" ]]; then
    command_json="$(json_escape "$LAST_REVIEW_COMMAND")"
  else
    command_json="null"
  fi

  printf '{"iteration":%s,"attempt":%s,"reason":%s,"output":%s,"artifact":%s,"exit_code":%s,"command":%s}' \
    "$ITERATION" \
    "$attempt" \
    "$(json_escape "$reason")" \
    "$output_json" \
    "$artifact_json" \
    "$exit_code_json" \
    "$command_json"
}

run_review_attempt() {
  local attempt="$1"
  local prompt="$2"
  local start_reason="${3:-}"
  local title review_rc
  local start_payload

  title="$(build_review_title)"
  LAST_REVIEW_OUTPUT="$RUN_TMP_DIR/review-iter-${ITERATION}-attempt-${attempt}.txt"
  LAST_REVIEW_EXIT_CODE=""
  LAST_REVIEW_ARTIFACT=""
  LAST_REVIEW_COMMAND="$(build_review_command_summary "$title")"

  start_payload="{\"iteration\":${ITERATION},\"attempt\":${attempt}"
  if [[ -n "$start_reason" ]]; then
    start_payload+=",\"reason\":$(json_escape "$start_reason")"
  fi
  start_payload+="}"
  emit_supervisor_event "review_started" "$start_payload"
  if (
    cd "$REPO_PATH"
    TIMEOUT="$REVIEW_TIMEOUT" "$SAFE_REVIEW_BIN" codex review --base "$BASE_BRANCH" --title "$title" "$prompt"
  ) > "$LAST_REVIEW_OUTPUT" 2>&1; then
    LAST_REVIEW_EXIT_CODE="0"
    return 0
  else
    review_rc=$?
  fi

  LAST_REVIEW_EXIT_CODE="$review_rc"
  persist_terminal_review_artifact "$attempt"
  emit_supervisor_event "review_failed" "$(build_review_failure_payload "$attempt" "review_command_nonzero")"
  write_state "failed" "review_command_failed"
  emit_run_event "failed" "phase=review-loop-supervisor reason=review_command_failed iteration=${ITERATION}"
  exit 1
}

run_review_with_parse_retry() {
  local review_prompt correction_prompt

  review_prompt="$(review_prompt_base)"
  if [[ -n "$ISSUE_NUMBER" ]]; then
    review_prompt+=$'\n'
    review_prompt+="Context issue: #$ISSUE_NUMBER"
  fi

  run_review_attempt 1 "$review_prompt"

  if parse_review_footer "$LAST_REVIEW_OUTPUT"; then
    emit_supervisor_event "review_completed" "{\"iteration\":${ITERATION},\"attempt\":1,\"parse\":\"ok\"}"
    return 0
  fi

  correction_prompt="$review_prompt"$'\n\n'
  correction_prompt+="Your prior response was missing strict SUPERVISOR_* footer lines. Re-run review and output valid machine footer exactly."

  run_review_attempt 2 "$correction_prompt" "parse_retry"

  if parse_review_footer "$LAST_REVIEW_OUTPUT"; then
    emit_supervisor_event "review_completed" "{\"iteration\":${ITERATION},\"attempt\":2,\"parse\":\"ok\"}"
    return 0
  fi

  persist_terminal_review_artifact 2
  emit_supervisor_event "review_failed" "$(build_review_failure_payload 2 "parse_failed")"
  write_state "failed" "parse_failed"
  emit_run_event "failed" "phase=review-loop-supervisor reason=parse_failed iteration=${ITERATION}"
  exit 1
}

run_fix() {
  local fix_prompt fingerprint_before fingerprint_after
  fingerprint_before="$(repo_content_fingerprint)"

  fix_prompt="Fix the open blockers in this repository until P0/P1/P2 are reduced.\n"
  fix_prompt+="Current counts: P0=${COUNT_P0}, P1=${COUNT_P1}, P2=${COUNT_P2}, P3=${COUNT_P3}.\n"
  fix_prompt+="Top blockers:\n"
  fix_prompt+="- P0: ${TOP_P0_LOCATION} :: ${TOP_P0_ISSUE} :: ${TOP_P0_PATCH}\n"
  fix_prompt+="- P1: ${TOP_P1_LOCATION} :: ${TOP_P1_ISSUE} :: ${TOP_P1_PATCH}\n"
  fix_prompt+="- P2: ${TOP_P2_LOCATION} :: ${TOP_P2_ISSUE} :: ${TOP_P2_PATCH}\n"
  fix_prompt+="Make only necessary changes and keep implementation maintainable."

  LAST_FIX_OUTPUT="$RUN_TMP_DIR/fix-iter-${ITERATION}.txt"
  emit_supervisor_event "fix_started" "{\"iteration\":${ITERATION}}"
  if ! (
    cd "$REPO_PATH"
    timeout "${FIX_TIMEOUT}s" codex -c 'model_reasoning_effort="high"' exec --full-auto "$fix_prompt"
  ) > "$LAST_FIX_OUTPUT" 2>&1; then
    emit_supervisor_event "fix_failed" "{\"iteration\":${ITERATION},\"reason\":\"codex_exec_nonzero\"}"
    write_state "failed" "fix_command_failed"
    emit_run_event "failed" "phase=review-loop-supervisor reason=fix_command_failed iteration=${ITERATION}"
    exit 1
  fi
  fingerprint_after="$(repo_content_fingerprint)"

  emit_supervisor_event "fix_completed" "{\"iteration\":${ITERATION}}"

  if [[ "$fingerprint_after" == "$fingerprint_before" ]]; then
    emit_supervisor_event "terminal" "{\"state\":\"stuck\",\"reason\":\"no_changes_after_fix\",\"iteration\":${ITERATION}}"
    write_state "stuck" "no_changes_after_fix"
    emit_run_event "failed" "phase=review-loop-supervisor reason=no_changes_after_fix iteration=${ITERATION}"
    exit 1
  fi
}

ensure_mutation_preconditions() {
  refresh_head_state

  case "$HEAD_BRANCH" in
    main|master)
      echo "Error: refusing mutating PR operations on protected branch '$HEAD_BRANCH'." >&2
      exit 1
      ;;
  esac
}

build_default_pr_title() {
  if [[ -n "$ISSUE_NUMBER" ]]; then
    printf 'fix(review-loop): clear P0-P2 blockers for #%s\n' "$ISSUE_NUMBER"
  else
    printf 'fix(review-loop): clear P0-P2 blockers\n'
  fi
}

build_default_pr_body() {
  local tests_block issue_block
  tests_block="- ./scripts/review-loop-supervisor --repo \"$REPO_PATH\" --base \"$BASE_BRANCH\""
  if (( ${#TEST_COMMANDS[@]} > 0 )); then
    local cmd
    for cmd in "${TEST_COMMANDS[@]}"; do
      tests_block+=$'\n'
      tests_block+="- \`$cmd\`"
    done
  fi

  issue_block=""
  if [[ -n "$ISSUE_NUMBER" ]]; then
    issue_block="Relates to #$ISSUE_NUMBER"
  fi

  cat <<EOFPR
## What
- Run supervised review/fix loop until P0/P1/P2 blockers clear.
- Persist loop state artifacts under \.ai/review-loops\/. 
- Emit machine-checkable supervisor milestone and delta events.

## Why
- Reduce manual status polling and make long-running review loops observable.

## Tests
$tests_block

## AI Assistance
- AI-assisted: yes
- Tools/agents/models used: Codex CLI (review + exec)
- Testing level: lightly tested
- Human understanding confirmation: yes

$issue_block
EOFPR
}

sha256_cmd() {
  if command -v sha256sum >/dev/null 2>&1; then
    printf 'sha256sum\n'
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    printf 'shasum -a 256\n'
    return 0
  fi
  echo "Error: missing required checksum tool: sha256sum or shasum" >&2
  exit 1
}

repo_content_fingerprint() {
  local checksum_cmd
  checksum_cmd="$(sha256_cmd)"
  (
    cd "$REPO_PATH"
    {
      printf '%s\n' "===staged-diff==="
      git diff --cached --binary -- . ':(exclude).ai/review-loops/**' || true
      printf '%s\n' "===unstaged-diff==="
      git diff --binary -- . ':(exclude).ai/review-loops/**' || true
      printf '%s\n' "===untracked==="
      git ls-files --others --exclude-standard -- . ':(exclude).ai/review-loops/**' | LC_ALL=C sort | while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        if [[ -f "$path" ]]; then
          printf '%s  %s\n' "$($checksum_cmd "$path" | awk '{print $1}')" "$path"
        else
          printf 'NONREGULAR  %s\n' "$path"
        fi
      done
    } | $checksum_cmd | awk '{print $1}'
  )
}

gh_repo() {
  (
    cd "$REPO_PATH"
    gh "$@"
  )
}

remote_repo_slug() {
  local remote_name="$1"
  python3 - <<'PY' "$(git -C "$REPO_PATH" remote get-url "$remote_name" 2>/dev/null || true)"
from urllib.parse import urlparse
import sys

remote_url = sys.argv[1].strip()
if not remote_url:
    print("")
    raise SystemExit(0)

normalized = remote_url
if "github.com" not in normalized and not normalized.startswith("git@github.com:"):
    print("")
    raise SystemExit(0)
if normalized.endswith(".git"):
    normalized = normalized[:-4]
if normalized.startswith("git@github.com:"):
    normalized = normalized.replace("git@github.com:", "https://github.com/", 1)
if normalized.startswith("ssh://git@github.com/"):
    normalized = normalized.replace("ssh://git@github.com/", "https://github.com/", 1)

if "github.com/" in normalized:
    path = normalized.split("github.com/", 1)[1]
else:
    path = urlparse(normalized).path.lstrip("/")

parts = [part for part in path.split("/") if part]
if len(parts) < 2:
    print("")
    raise SystemExit(0)

print(f"{parts[0]}/{parts[1]}")
PY
}

pr_repo_parts() {
  python3 - <<'PY' "$PR_URL" "$(git -C "$REPO_PATH" remote get-url origin 2>/dev/null || true)"
from urllib.parse import urlparse
import sys

pr_url = sys.argv[1].strip()
remote_url = sys.argv[2].strip()

def emit(owner: str, repo: str) -> None:
    if not owner or not repo:
        print("")
        raise SystemExit(0)
    print(owner)
    print(repo)
    raise SystemExit(0)

if pr_url:
    parts = [part for part in urlparse(pr_url).path.split("/") if part]
    if len(parts) >= 4 and parts[2] == "pull":
        emit(parts[0], parts[1])

if remote_url:
    normalized = remote_url
    if normalized.endswith(".git"):
        normalized = normalized[:-4]
    if normalized.startswith("git@github.com:"):
        normalized = normalized.replace("git@github.com:", "https://github.com/", 1)
    if normalized.startswith("ssh://git@github.com/"):
        normalized = normalized.replace("ssh://git@github.com/", "https://github.com/", 1)
    if "github.com/" in normalized:
        path = normalized.split("github.com/", 1)[1]
        parts = [part for part in path.split("/") if part]
        if len(parts) >= 2:
            emit(parts[0], parts[1])

print("")
PY
}

candidate_repo_slugs() {
  local repo_parts upstream_remote push_remote remote_name slug seen_slugs=""

  add_slug() {
    local value="$1"
    if [[ -z "$value" || " $seen_slugs " == *" $value "* ]]; then
      return
    fi
    seen_slugs="${seen_slugs}${seen_slugs:+ }$value"
    printf '%s\n' "$value"
  }

  repo_parts="$(pr_repo_parts)"
  slug="$(printf '%s\n' "$repo_parts" | paste -sd/ -)"
  add_slug "$slug"

  upstream_remote="$(git -C "$REPO_PATH" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null | sed 's#/.*##' || true)"
  push_remote="$(git -C "$REPO_PATH" config --get remote.pushDefault 2>/dev/null || true)"

  for remote_name in "$upstream_remote" "$push_remote" upstream origin; do
    [[ -n "$remote_name" ]] || continue
    add_slug "$(remote_repo_slug "$remote_name")"
  done

  while IFS= read -r remote_name; do
    [[ -n "$remote_name" ]] || continue
    add_slug "$(remote_repo_slug "$remote_name")"
  done < <(git -C "$REPO_PATH" remote)
}

ensure_pr_context() {
  local pr_json slug

  refresh_head_state

  while IFS= read -r slug; do
    [[ -n "$slug" ]] || continue
    pr_json="$(gh_repo pr view "$HEAD_BRANCH" --repo "$slug" --json number,url 2>/dev/null || true)"
    if [[ -n "$pr_json" && "$pr_json" != "null" ]]; then
      break
    fi
  done < <(candidate_repo_slugs)

  if [[ -z "$pr_json" || "$pr_json" == "null" ]]; then
    return 1
  fi

  PR_NUMBER="$(python3 - <<'PY' "$pr_json"
import json
import sys

try:
    payload = json.loads(sys.argv[1])
except Exception:
    print("")
    raise SystemExit(0)

print(payload.get("number", ""))
PY
)"
  if [[ -z "$PR_NUMBER" ]]; then
    return 1
  fi

  if [[ -z "$PR_URL" ]]; then
    PR_URL="$(python3 - <<'PY' "$pr_json"
import json
import sys

try:
    payload = json.loads(sys.argv[1])
except Exception:
    print("")
    raise SystemExit(0)

print(payload.get("url", ""))
PY
)"
  fi

  return 0
}

fetch_github_review_payload() {
  local repo_parts owner repo_name

  if ! ensure_pr_context; then
    return 1
  fi

  repo_parts="$(pr_repo_parts)"
  owner="$(printf '%s\n' "$repo_parts" | sed -n '1p')"
  repo_name="$(printf '%s\n' "$repo_parts" | sed -n '2p')"
  if [[ -z "$owner" || -z "$repo_name" ]]; then
    return 1
  fi
  # shellcheck disable=SC2016
  gh_repo api graphql \
    -F owner="$owner" \
    -F repo="$repo_name" \
    -F pr="$PR_NUMBER" \
    -f query='query($owner:String!, $repo:String!, $pr:Int!) {
      repository(owner:$owner, name:$repo) {
        pullRequest(number:$pr) {
          number
          url
          headRefOid
          reviews(last:100) {
            nodes {
              author { login }
              state
              submittedAt
              url
              commit { oid }
            }
          }
        }
      }
    }'
}

summarize_github_review_payload() {
  python3 - <<'PY' "$1" "$HEAD_SHA" "${GITHUB_REVIEW_AUTHORS[*]:-}"
import json
import sys

payload = json.loads(sys.argv[1])
head_sha = sys.argv[2]
authors = [value for value in sys.argv[3].split() if value]

pr = (((payload.get("data") or {}).get("repository") or {}).get("pullRequest") or {})
if not pr:
    print(json.dumps({"status": "missing_pr"}))
    raise SystemExit(0)

pr_head_sha = pr.get("headRefOid")
reviews = ((pr.get("reviews") or {}).get("nodes") or [])
candidates = []
for review in reviews:
    commit = (review.get("commit") or {}).get("oid")
    author = ((review.get("author") or {}).get("login")) or ""
    if commit != head_sha:
        continue
    if authors and author not in authors:
        continue
    candidates.append(review)

latest = None
if candidates:
    latest = sorted(candidates, key=lambda review: review.get("submittedAt") or "")[-1]

status = "pending_review"
if pr_head_sha != head_sha:
    status = "pending_head"
elif latest:
    status = "matched"

print(json.dumps({
    "status": status,
    "pr_url": pr.get("url"),
    "pr_head_sha": pr_head_sha,
    "matched_review_url": (latest or {}).get("url"),
    "matched_review_author": (((latest or {}).get("author") or {}).get("login")),
    "matched_review_submitted_at": (latest or {}).get("submittedAt"),
}))
PY
}

wait_for_github_review_closure() {
  local start_ts now elapsed review_payload="" review_summary="" summary_status="" pr_head_sha=""
  local matched_review_url="" matched_review_author="" matched_review_submitted_at=""

  if [[ "$CLOSURE_MODE" != "github" ]]; then
    return 0
  fi

  if [[ -n "$(repo_status_filtered)" ]]; then
    write_state "failed" "github_review_requires_clean_pushed_head"
    emit_supervisor_event "terminal" "{\"state\":\"failed\",\"reason\":\"github_review_requires_clean_pushed_head\",\"iteration\":${ITERATION}}"
    emit_run_event "failed" "phase=review-loop-supervisor reason=github_review_requires_clean_pushed_head iteration=${ITERATION}"
    exit 1
  fi

  emit_supervisor_event "github_review_started" "{\"iteration\":${ITERATION},\"head_sha\":$(json_escape "$HEAD_SHA"),\"poll_seconds\":${GITHUB_REVIEW_POLL_SECONDS},\"wait_seconds\":${GITHUB_REVIEW_WAIT_SECONDS}}"
  GITHUB_REVIEW_STATUS="pending"
  write_state "running" "github_review_wait_started"
  start_ts="$(date +%s)"

  while true; do
    maybe_heartbeat "github_review"
    review_payload="$(fetch_github_review_payload 2>/dev/null || true)"
    if [[ -n "$review_payload" ]]; then
      review_summary="$(summarize_github_review_payload "$review_payload")"
      summary_status="$(python3 - <<'PY' "$review_summary"
import json
import sys
print((json.loads(sys.argv[1]) or {}).get("status", "missing_pr"))
PY
)"
      pr_head_sha="$(python3 - <<'PY' "$review_summary"
import json
import sys
print((json.loads(sys.argv[1]) or {}).get("pr_head_sha") or "")
PY
)"
      matched_review_url="$(python3 - <<'PY' "$review_summary"
import json
import sys
print((json.loads(sys.argv[1]) or {}).get("matched_review_url") or "")
PY
)"
      matched_review_author="$(python3 - <<'PY' "$review_summary"
import json
import sys
print((json.loads(sys.argv[1]) or {}).get("matched_review_author") or "")
PY
)"
      matched_review_submitted_at="$(python3 - <<'PY' "$review_summary"
import json
import sys
print((json.loads(sys.argv[1]) or {}).get("matched_review_submitted_at") or "")
PY
)"

      if [[ "$summary_status" == "matched" ]]; then
        GITHUB_REVIEW_STATUS="cleared"
        GITHUB_REVIEW_URL="$matched_review_url"
        GITHUB_REVIEW_AUTHOR="$matched_review_author"
        GITHUB_REVIEW_SUBMITTED_AT="$matched_review_submitted_at"
        emit_supervisor_event "github_review_cleared" "{\"iteration\":${ITERATION},\"head_sha\":$(json_escape "$HEAD_SHA"),\"review_url\":$(json_escape "$GITHUB_REVIEW_URL"),\"author\":$(json_escape "$GITHUB_REVIEW_AUTHOR")}"
        write_state "ready" "github_review_cleared"
        return 0
      fi

      if [[ "$summary_status" == "missing_pr" ]]; then
        GITHUB_REVIEW_STATUS="missing_pr"
      elif [[ "$summary_status" == "pending_head" ]]; then
        GITHUB_REVIEW_STATUS="pending_head"
      else
        GITHUB_REVIEW_STATUS="pending_review"
      fi
      write_state "running" "github_review_waiting"
    else
      GITHUB_REVIEW_STATUS="missing_pr"
      write_state "running" "github_review_waiting"
    fi

    now="$(date +%s)"
    elapsed=$(( now - start_ts ))
    if (( elapsed >= GITHUB_REVIEW_WAIT_SECONDS )); then
      emit_supervisor_event "terminal" "{\"state\":\"pending_github_review\",\"reason\":\"github_review_not_visible_for_head\",\"iteration\":${ITERATION},\"head_sha\":$(json_escape "$HEAD_SHA"),\"pr_head_sha\":$(json_escape "$pr_head_sha")}"
      write_state "pending_github_review" "github_review_not_visible_for_head"
      emit_run_event "failed" "phase=review-loop-supervisor reason=pending_github_review iteration=${ITERATION}"
      exit 1
    fi
    sleep "$GITHUB_REVIEW_POLL_SECONDS"
  done
}

open_or_update_pr() {
  ensure_mutation_preconditions

  local title body body_tmp existing_pr_json existing_pr_url existing_pr_number existing_pr_repo_slug="" slug

  if [[ -n "$PR_TITLE" ]]; then
    title="$PR_TITLE"
  else
    title="$(build_default_pr_title)"
  fi

  if [[ -n "$PR_BODY_FILE" ]]; then
    body="$(cat "$PR_BODY_FILE")"
  elif [[ -n "$PR_BODY" ]]; then
    body="$PR_BODY"
  else
    body="$(build_default_pr_body)"
  fi

  if [[ -n "$(repo_status_filtered)" ]]; then
    local commit_subject
    if [[ -n "$COMMIT_MSG" ]]; then
      commit_subject="$COMMIT_MSG"
    else
      commit_subject="fix(review-loop): address supervisor findings"
    fi
    git -C "$REPO_PATH" add -A
    git -C "$REPO_PATH" reset -q -- .ai/review-loops || true
    if ! git -C "$REPO_PATH" diff --cached --quiet; then
      git -C "$REPO_PATH" commit -m "$commit_subject"
    fi
  fi

  refresh_head_state

  if git -C "$REPO_PATH" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    git -C "$REPO_PATH" push
  else
    git -C "$REPO_PATH" push -u origin "$HEAD_BRANCH"
  fi

  while IFS= read -r slug; do
    [[ -n "$slug" ]] || continue
    existing_pr_json="$(gh_repo pr view "$HEAD_BRANCH" --repo "$slug" --json number,url 2>/dev/null || true)"
    if [[ -n "$existing_pr_json" && "$existing_pr_json" != "null" ]]; then
      existing_pr_repo_slug="$slug"
      break
    fi
  done < <(candidate_repo_slugs)

  if [[ -n "$existing_pr_json" ]]; then
    existing_pr_number="$(python3 - <<'PY' "$existing_pr_json"
import json
import sys
raw = sys.argv[1]
try:
    payload = json.loads(raw)
except Exception:
    print("")
    raise SystemExit(0)
print((payload or {}).get("number", ""))
PY
)"
    existing_pr_url="$(python3 - <<'PY' "$existing_pr_json"
import json
import sys
raw = sys.argv[1]
try:
    payload = json.loads(raw)
except Exception:
    print("")
    raise SystemExit(0)
print((payload or {}).get("url", ""))
PY
)"
    if [[ -n "$existing_pr_number" ]]; then
      body_tmp="$RUN_TMP_DIR/pr-body.md"
      printf '%s\n' "$body" > "$body_tmp"
      gh_repo pr edit "$existing_pr_number" --repo "$existing_pr_repo_slug" --title "$title" --body-file "$body_tmp"
      PR_URL="$existing_pr_url"
      emit_supervisor_event "pr_updated" "{\"number\":${existing_pr_number},\"url\":$(json_escape "$PR_URL") }"
      return 0
    fi
  fi

  body_tmp="$RUN_TMP_DIR/pr-body.md"
  printf '%s\n' "$body" > "$body_tmp"
  PR_URL="$(gh_repo pr create --base "$BASE_BRANCH" --head "$HEAD_BRANCH" --title "$title" --body-file "$body_tmp" | tail -n 1)"
  emit_supervisor_event "pr_created" "{\"url\":$(json_escape "$PR_URL") }"
}

REPO_PATH="$(pwd)"
BASE_BRANCH=""
CLOSURE_MODE="local"
GITHUB_REVIEW_WAIT_SECONDS=180
GITHUB_REVIEW_POLL_SECONDS=15
GITHUB_REVIEW_AUTHORS=()
REVIEW_TIMEOUT=900
FIX_TIMEOUT=900
MAX_RUNTIME_SECONDS=5400
STATUS_INTERVAL_SECONDS=120
OPEN_PR=0
ISSUE_NUMBER=""
ISSUE_NUMBER_JSON="null"
COMMIT_MSG=""
PR_TITLE=""
PR_BODY=""
PR_BODY_FILE=""
TEST_COMMANDS=()
SAFE_REVIEW_BIN="${REVIEW_LOOP_SAFE_REVIEW_BIN:-$SCRIPT_DIR/safe-review.sh}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPO_PATH="${2:-}"
      shift 2
      ;;
    --base)
      BASE_BRANCH="${2:-}"
      shift 2
      ;;
    --test-cmd)
      TEST_COMMANDS+=("${2:-}")
      shift 2
      ;;
    --closure-mode)
      CLOSURE_MODE="${2:-}"
      shift 2
      ;;
    --github-review-author)
      GITHUB_REVIEW_AUTHORS+=("${2:-}")
      shift 2
      ;;
    --github-review-wait-seconds)
      GITHUB_REVIEW_WAIT_SECONDS="${2:-}"
      shift 2
      ;;
    --github-review-poll-seconds)
      GITHUB_REVIEW_POLL_SECONDS="${2:-}"
      shift 2
      ;;
    --review-timeout)
      REVIEW_TIMEOUT="${2:-}"
      shift 2
      ;;
    --fix-timeout)
      FIX_TIMEOUT="${2:-}"
      shift 2
      ;;
    --max-runtime-seconds)
      MAX_RUNTIME_SECONDS="${2:-}"
      shift 2
      ;;
    --status-interval-seconds)
      STATUS_INTERVAL_SECONDS="${2:-}"
      shift 2
      ;;
    --open-pr)
      OPEN_PR=1
      shift
      ;;
    --issue)
      ISSUE_NUMBER="${2:-}"
      shift 2
      ;;
    --commit-msg)
      COMMIT_MSG="${2:-}"
      shift 2
      ;;
    --pr-title)
      PR_TITLE="${2:-}"
      shift 2
      ;;
    --pr-body)
      PR_BODY="${2:-}"
      shift 2
      ;;
    --pr-body-file)
      PR_BODY_FILE="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown argument '$1'" >&2
      usage
      exit 1
      ;;
  esac
done

if [[ "$CLOSURE_MODE" != "local" && "$CLOSURE_MODE" != "github" ]]; then
  echo "Error: --closure-mode must be 'local' or 'github'." >&2
  exit 1
fi

ensure_number "github-review-wait-seconds" "$GITHUB_REVIEW_WAIT_SECONDS"
ensure_number "github-review-poll-seconds" "$GITHUB_REVIEW_POLL_SECONDS"
ensure_number "review-timeout" "$REVIEW_TIMEOUT"
ensure_number "fix-timeout" "$FIX_TIMEOUT"
ensure_number "max-runtime-seconds" "$MAX_RUNTIME_SECONDS"
ensure_number "status-interval-seconds" "$STATUS_INTERVAL_SECONDS"

if (( GITHUB_REVIEW_POLL_SECONDS == 0 )); then
  echo "Error: --github-review-poll-seconds must be at least 1." >&2
  exit 1
fi

if (( REVIEW_TIMEOUT < 600 )); then
  echo "Error: --review-timeout must be at least 600 seconds." >&2
  exit 1
fi

if [[ -n "$PR_BODY" && -n "$PR_BODY_FILE" ]]; then
  echo "Error: --pr-body and --pr-body-file are mutually exclusive." >&2
  exit 1
fi

if [[ -n "$PR_BODY_FILE" && ! -f "$PR_BODY_FILE" ]]; then
  echo "Error: --pr-body-file does not exist: $PR_BODY_FILE" >&2
  exit 1
fi

if [[ -n "$ISSUE_NUMBER" ]]; then
  if [[ ! "$ISSUE_NUMBER" =~ ^[0-9]+$ ]]; then
    echo "Error: --issue must be numeric." >&2
    exit 1
  fi
  ISSUE_NUMBER_JSON="$ISSUE_NUMBER"
fi

if [[ ! -d "$REPO_PATH" ]]; then
  echo "Error: --repo path does not exist: $REPO_PATH" >&2
  exit 1
fi

ensure_tooling
if ! git -C "$REPO_PATH" rev-parse --git-dir >/dev/null 2>&1; then
  echo "Error: --repo is not a git repository: $REPO_PATH" >&2
  exit 1
fi

BASE_BRANCH="$(derive_base_branch)"
refresh_head_state

mkdir -p "$(state_dir_path)"
RUN_TS="$(date +%Y%m%d-%H%M%S)"
STATE_HISTORY_FILE="$(state_dir_path)/${RUN_TS}-${HEAD_BRANCH//\//-}.json"
STATE_LATEST_FILE="$(state_dir_path)/latest.json"
RUN_TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$RUN_TMP_DIR"' EXIT

COUNT_P0=0
COUNT_P1=0
COUNT_P2=0
COUNT_P3=0
DELTA_P0=0
DELTA_P1=0
DELTA_P2=0
DELTA_P3=0
PREV_P0=0
PREV_P1=0
PREV_P2=0
PREV_P3=0
TOP_P0_LOCATION="none"
TOP_P0_ISSUE="none"
TOP_P0_PATCH="none"
TOP_P1_LOCATION="none"
TOP_P1_ISSUE="none"
TOP_P1_PATCH="none"
TOP_P2_LOCATION="none"
TOP_P2_ISSUE="none"
TOP_P2_PATCH="none"
TOP_P3_LOCATION="none"
TOP_P3_ISSUE="none"
TOP_P3_PATCH="none"
LAST_REVIEW_OUTPUT=""
LAST_REVIEW_EXIT_CODE=""
LAST_REVIEW_COMMAND=""
LAST_REVIEW_ARTIFACT=""
LAST_FIX_OUTPUT=""
GITHUB_REVIEW_STATUS="not_requested"
GITHUB_REVIEW_URL=""
GITHUB_REVIEW_AUTHOR=""
GITHUB_REVIEW_SUBMITTED_AT=""
PR_NUMBER=""
PR_URL=""
ITERATION=0
CURRENT_STATE="preflight"
START_TS="$(date +%s)"
LAST_STATUS_TS="$START_TS"

trap 'handle_supervisor_signal INT' INT
trap 'handle_supervisor_signal TERM' TERM

emit_run_event "start" "phase=review-loop-supervisor repo=$REPO_PATH base=$BASE_BRANCH branch=$HEAD_BRANCH closure_mode=$CLOSURE_MODE"
emit_supervisor_event "start" "{\"repo\":$(json_escape "$REPO_PATH"),\"base\":$(json_escape "$BASE_BRANCH"),\"branch\":$(json_escape "$HEAD_BRANCH"),\"head_sha\":$(json_escape "$HEAD_SHA"),\"open_pr\":${OPEN_PR},\"closure_mode\":$(json_escape "$CLOSURE_MODE")}"
write_state "running" "started"

if (( OPEN_PR == 1 )) && [[ -n "$(repo_status_filtered)" ]]; then
  echo "Error: --open-pr requires a clean working tree at start." >&2
  echo "Implementation changes must already be committed before starting review-loop-supervisor --open-pr." >&2
  echo "Commit the generated changes on the feature branch, then rerun review-loop-supervisor." >&2
  write_state "failed" "open_pr_requires_clean_tree"
  emit_run_event "failed" "phase=review-loop-supervisor reason=open_pr_requires_clean_tree"
  exit 1
fi

run_tests "initial"

while true; do
  ITERATION=$(( ITERATION + 1 ))
  CURRENT_STATE="review"
  check_runtime_budget
  maybe_heartbeat "review"

  run_review_with_parse_retry
  emit_delta_and_state_change_events

  write_state "running" "iteration_${ITERATION}_reviewed"

  if (( COUNT_P0 + COUNT_P1 + COUNT_P2 == 0 )); then
    CURRENT_STATE="ready"
    run_tests "pre_ready"
    write_state "ready" "p0_p2_cleared"
    emit_supervisor_event "ready" "{\"iteration\":${ITERATION},\"counts\":{\"P0\":${COUNT_P0},\"P1\":${COUNT_P1},\"P2\":${COUNT_P2},\"P3\":${COUNT_P3}}}"
    break
  fi

  CURRENT_STATE="fix"
  check_runtime_budget
  maybe_heartbeat "fix"
  run_fix
  write_state "running" "iteration_${ITERATION}_fixed"
done

if (( OPEN_PR == 1 )); then
  CURRENT_STATE="open_pr"
  emit_supervisor_event "pr_started" "{\"branch\":$(json_escape "$HEAD_BRANCH") }"
  open_or_update_pr
fi

if [[ "$CLOSURE_MODE" == "github" ]]; then
  CURRENT_STATE="github_review"
  refresh_head_state
  wait_for_github_review_closure
fi

write_state "done" "completed"
emit_run_event "done" "phase=review-loop-supervisor iteration=${ITERATION} state=done"
emit_supervisor_event "done" "{\"iteration\":${ITERATION},\"pr_url\":$( [[ -n "$PR_URL" ]] && json_escape "$PR_URL" || echo null ) }"

echo "Supervisor completed."
echo "State latest: $STATE_LATEST_FILE"
if [[ -n "$PR_URL" ]]; then
  echo "PR: $PR_URL"
fi
