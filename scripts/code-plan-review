#!/usr/bin/env bash
set -euo pipefail

export PATH="$PATH:/run/current-system/sw/bin"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
SYSTEM_PROMPT_FILE="$ROOT_DIR/references/templates/plan-review-system-prompt.txt"

usage() {
  cat >&2 <<'USAGE'
Usage:
  code-plan-review [--repo <path>] [--base <branch>] [--plan <path>] [--model <name>] [--output <path>] [--mode <batch|live|apply>] [--resolve-file <path>] [--decisions <csv>] [--blocking <csv|none>] [--non-tty <auto|error>]

Defaults:
  --repo   current working directory
  --base   auto-detected origin default branch (fallback: main)
  --plan   latest generated .ai/plans/*.md (timestamped filename)
  --output .ai/plan-reviews/<timestamp>-<plan-id>.md
  --mode   batch
  --non-tty auto
USAGE
}

REPO_PATH="$(pwd)"
BASE_BRANCH=""
PLAN_PATH=""
MODEL=""
OUTPUT_PATH=""
MODE="batch"
RESOLVE_FILE_PATH=""
DECISIONS_INPUT=""
BLOCKING_INPUT=""
NON_TTY_MODE="auto"
SECTION_TIMEOUT="${PLAN_REVIEW_LIVE_SECTION_TIMEOUT:-600}"
TOTAL_TIMEOUT="${PLAN_REVIEW_LIVE_TOTAL_TIMEOUT:-2400}"
ALLOW_NON_TTY="${PLAN_REVIEW_LIVE_ALLOW_NON_TTY:-0}"
STATUS_PING_SECONDS="${CODING_AGENT_STATUS_PING_SECONDS:-20}"
LONG_RUN_THRESHOLD_SECONDS="${CODING_AGENT_LONG_RUN_THRESHOLD_SECONDS:-30}"
SCHEMA_VERSION=1
LIVE_INCOMPLETE_MARKER="Live review incomplete or failed"
METADATA_WRITE_SEQ=0
CURRENT_CHILD_PID=""

emit_run_event() {
  local event="$1"
  local details="${2:-}"
  if [[ -n "$details" ]]; then
    echo "RUN_EVENT $event ts=$(date -Iseconds) $details" >&2
  else
    echo "RUN_EVENT $event ts=$(date -Iseconds)" >&2
  fi
}

validate_positive_int() {
  local value="$1"
  local name="$2"
  if [[ ! "$value" =~ ^[0-9]+$ ]] || (( value <= 0 )); then
    echo "Error: $name must be a positive integer, got '$value'" >&2
    exit 1
  fi
}

handle_interrupt() {
  local signal_name="$1"
  emit_run_event "interrupted" "phase=plan-review mode=$MODE signal=$signal_name"
  if [[ -n "$CURRENT_CHILD_PID" ]] && kill -0 "$CURRENT_CHILD_PID" >/dev/null 2>&1; then
    kill "-$signal_name" "$CURRENT_CHILD_PID" >/dev/null 2>&1 || true
  fi
  exit 130
}

trap 'handle_interrupt INT' INT
trap 'handle_interrupt TERM' TERM

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPO_PATH="${2:-}"
      shift 2
      ;;
    --base)
      BASE_BRANCH="${2:-}"
      shift 2
      ;;
    --plan)
      PLAN_PATH="${2:-}"
      shift 2
      ;;
    --model)
      MODEL="${2:-}"
      shift 2
      ;;
    --output)
      OUTPUT_PATH="${2:-}"
      shift 2
      ;;
    --mode)
      MODE="${2:-}"
      shift 2
      ;;
    --resolve-file)
      RESOLVE_FILE_PATH="${2:-}"
      shift 2
      ;;
    --decisions)
      DECISIONS_INPUT="${2:-}"
      shift 2
      ;;
    --blocking)
      BLOCKING_INPUT="${2:-}"
      shift 2
      ;;
    --non-tty)
      NON_TTY_MODE="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown argument: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if [[ "$MODE" != "batch" && "$MODE" != "live" && "$MODE" != "apply" ]]; then
  echo "Error: --mode must be batch, live, or apply" >&2
  exit 1
fi

if [[ "$NON_TTY_MODE" != "auto" && "$NON_TTY_MODE" != "error" ]]; then
  echo "Error: --non-tty must be auto or error" >&2
  exit 1
fi

validate_positive_int "$STATUS_PING_SECONDS" "CODING_AGENT_STATUS_PING_SECONDS"
validate_positive_int "$LONG_RUN_THRESHOLD_SECONDS" "CODING_AGENT_LONG_RUN_THRESHOLD_SECONDS"

if [[ -n "$RESOLVE_FILE_PATH" && ( -n "$DECISIONS_INPUT" || -n "$BLOCKING_INPUT" ) ]]; then
  echo "Error: --resolve-file cannot be combined with --decisions or --blocking." >&2
  exit 1
fi

if [[ "$MODE" == "live" ]]; then
  if [[ ! "$SECTION_TIMEOUT" =~ ^[0-9]+$ ]] || (( SECTION_TIMEOUT <= 0 )); then
    echo "Error: PLAN_REVIEW_LIVE_SECTION_TIMEOUT must be a positive integer (seconds)" >&2
    exit 1
  fi
  if [[ ! "$TOTAL_TIMEOUT" =~ ^[0-9]+$ ]] || (( TOTAL_TIMEOUT <= 0 )); then
    echo "Error: PLAN_REVIEW_LIVE_TOTAL_TIMEOUT must be a positive integer (seconds)" >&2
    exit 1
  fi
fi

REPO_PATH="$(cd "$REPO_PATH" && pwd)"
if ! git -C "$REPO_PATH" rev-parse --git-dir >/dev/null 2>&1; then
  echo "Error: --repo must point to a git repository" >&2
  exit 1
fi

if [[ -z "$BASE_BRANCH" ]]; then
  BASE_BRANCH="$(git -C "$REPO_PATH" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || true)"
fi
if [[ -z "$BASE_BRANCH" ]]; then
  BASE_BRANCH="main"
fi

select_latest_generated_plan() {
  local dir="$1"
  local best_path=""
  local best_name=""
  local path
  local name

  shopt -s nullglob
  for path in "$dir"/*.md; do
    name="$(basename "$path")"
    if [[ "$name" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{6}-.*\.md$ ]]; then
      if [[ -z "$best_name" || "$name" > "$best_name" ]]; then
        best_name="$name"
        best_path="$path"
      fi
    fi
  done
  shopt -u nullglob

  if [[ -n "$best_path" ]]; then
    printf '%s\n' "$best_path"
  fi
}

if [[ -z "$PLAN_PATH" ]]; then
  PLAN_PATH="$(select_latest_generated_plan "$REPO_PATH/.ai/plans")"
fi
if [[ -z "$PLAN_PATH" ]]; then
  echo "Error: no generated plan found. Provide --plan or run scripts/plan first." >&2
  exit 1
fi

if [[ "$PLAN_PATH" != /* ]]; then
  PLAN_PATH="$REPO_PATH/$PLAN_PATH"
fi
if [[ ! -f "$PLAN_PATH" ]]; then
  echo "Error: plan file not found: $PLAN_PATH" >&2
  exit 1
fi

PLAN_FILENAME="$(basename "$PLAN_PATH")"
PLAN_ID="${PLAN_FILENAME%.md}"
CURRENT_BRANCH="$(git -C "$REPO_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
HEAD_SHA="$(git -C "$REPO_PATH" rev-parse HEAD 2>/dev/null || echo unknown)"
CREATED_AT="$(date -Iseconds)"

REVIEW_DIR="$REPO_PATH/.ai/plan-reviews"
mkdir -p "$REVIEW_DIR"

if [[ -z "$OUTPUT_PATH" ]]; then
  TIMESTAMP="$(date +"%Y-%m-%d-%H%M%S")"
  OUTPUT_PATH="$REVIEW_DIR/${TIMESTAMP}-${PLAN_ID}.md"
fi
if [[ "$OUTPUT_PATH" != /* ]]; then
  OUTPUT_PATH="$REPO_PATH/$OUTPUT_PATH"
fi
mkdir -p "$(dirname "$OUTPUT_PATH")"

TIMESTAMP="$(date +"%Y-%m-%d-%H%M%S")"
METADATA_RUN_ID="${TIMESTAMP}-$$-${RANDOM}"
if ns="$(date +%N 2>/dev/null)"; then
  if [[ "$ns" =~ ^[0-9]+$ ]]; then
    METADATA_RUN_ID="${TIMESTAMP}-${ns}-$$-${RANDOM}"
  fi
fi
METADATA_HISTORY_PREFIX="$REVIEW_DIR/${TIMESTAMP}-${PLAN_ID}-${METADATA_RUN_ID}"
METADATA_LATEST_PATH="$REVIEW_DIR/latest-${PLAN_ID}.json"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
SYSTEM_PROMPT="$TMP_DIR/system_prompt.txt"
TMP_OUTPUT="$TMP_DIR/review-output.md"
RESOLVED_FILE="$TMP_DIR/resolved-decisions.txt"
BLOCKING_FILE="$TMP_DIR/blocking-decisions.txt"
: > "$RESOLVED_FILE"
: > "$BLOCKING_FILE"

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

trim_value() {
  local value="$1"
  value="$(printf '%s' "$value" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
  printf '%s' "$value"
}

append_list_entries() {
  local raw="$1"
  local file="$2"
  local normalized
  local part
  local trimmed
  local lowered
  normalized="${raw//$'\n'/,}"
  IFS=',' read -r -a parts <<< "$normalized"
  for part in "${parts[@]}"; do
    trimmed="$(trim_value "$part")"
    if [[ -z "$trimmed" ]]; then
      continue
    fi
    lowered="$(printf '%s' "$trimmed" | tr '[:upper:]' '[:lower:]')"
    if [[ "$lowered" == "none" ]]; then
      continue
    fi
    printf '%s\n' "$trimmed" >> "$file"
  done
}

dedupe_file() {
  local file="$1"
  local tmp_file
  tmp_file="$(mktemp)"
  awk 'NF && !seen[$0]++' "$file" > "$tmp_file"
  mv "$tmp_file" "$file"
}

json_array_from_file() {
  local file="$1"
  local first=1
  local line
  printf '['
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$line" ]]; then
      continue
    fi
    if (( first == 0 )); then
      printf ', '
    fi
    first=0
    printf '"%s"' "$(json_escape "$line")"
  done < "$file"
  printf ']'
}

has_resolution_inputs() {
  if [[ -n "$RESOLVE_FILE_PATH" || -n "$DECISIONS_INPUT" || -n "$BLOCKING_INPUT" ]]; then
    return 0
  fi
  return 1
}

resolution_usage_hint() {
  cat >&2 <<'EOF'
Examples:
  ./scripts/plan-review-live --repo /path/to/repo --decisions "1A,2B,3A,4A" --blocking none
  ./scripts/plan-review-live --repo /path/to/repo --resolve-file /path/to/decisions.json
EOF
}

parse_resolution_file() {
  local source_path="$1"
  local resolved_out="$2"
  local blocking_out="$3"
  local abs_path="$source_path"

  if [[ "$abs_path" != /* ]]; then
    abs_path="$REPO_PATH/$abs_path"
  fi
  if [[ ! -f "$abs_path" ]]; then
    echo "Error: --resolve-file not found: $abs_path" >&2
    exit 1
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required to parse --resolve-file JSON input." >&2
    exit 1
  fi

  if ! python3 - "$abs_path" "$resolved_out" "$blocking_out" <<'PY'
import json
import sys
from pathlib import Path

resolve_path = Path(sys.argv[1])
resolved_out = Path(sys.argv[2])
blocking_out = Path(sys.argv[3])

try:
    payload = json.loads(resolve_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"Error: invalid resolve file JSON: {exc}", file=sys.stderr)
    raise SystemExit(1)

if not isinstance(payload, dict):
    print("Error: resolve file must be a JSON object.", file=sys.stderr)
    raise SystemExit(1)

for key in ("resolved_decisions", "blocking_decisions"):
    if key not in payload:
        print(f"Error: resolve file missing required key '{key}'.", file=sys.stderr)
        raise SystemExit(1)
    if not isinstance(payload[key], list):
        print(f"Error: resolve file key '{key}' must be an array of strings.", file=sys.stderr)
        raise SystemExit(1)

def normalize(values, key_name):
    normalized = []
    for idx, value in enumerate(values):
        if not isinstance(value, str):
            print(
                f"Error: resolve file key '{key_name}' contains non-string entry at index {idx}.",
                file=sys.stderr,
            )
            raise SystemExit(1)
        trimmed = value.strip()
        if not trimmed:
            continue
        if trimmed.lower() == "none":
            continue
        normalized.append(trimmed)
    return normalized

resolved = normalize(payload["resolved_decisions"], "resolved_decisions")
blocking = normalize(payload["blocking_decisions"], "blocking_decisions")

resolved_out.write_text("".join(f"{item}\n" for item in resolved), encoding="utf-8")
blocking_out.write_text("".join(f"{item}\n" for item in blocking), encoding="utf-8")
PY
  then
    exit 1
  fi
}

load_resolution_inputs() {
  : > "$RESOLVED_FILE"
  : > "$BLOCKING_FILE"

  if [[ -n "$RESOLVE_FILE_PATH" ]]; then
    parse_resolution_file "$RESOLVE_FILE_PATH" "$RESOLVED_FILE" "$BLOCKING_FILE"
  else
    append_list_entries "$DECISIONS_INPUT" "$RESOLVED_FILE"
    append_list_entries "$BLOCKING_INPUT" "$BLOCKING_FILE"
  fi
}

write_metadata() {
  local ready="$1"
  local mode_override="${2:-$MODE}"
  local history_path
  local tmp_meta
  local latest_tmp
  local resolved_json
  local blocking_json
  METADATA_WRITE_SEQ=$((METADATA_WRITE_SEQ + 1))
  history_path="${METADATA_HISTORY_PREFIX}-${METADATA_WRITE_SEQ}.json"
  tmp_meta="$(mktemp)"
  latest_tmp="$(mktemp)"

  dedupe_file "$RESOLVED_FILE"
  dedupe_file "$BLOCKING_FILE"

  resolved_json="$(json_array_from_file "$RESOLVED_FILE")"
  blocking_json="$(json_array_from_file "$BLOCKING_FILE")"

  cat > "$tmp_meta" <<EOF
{
  "schema_version": $SCHEMA_VERSION,
  "plan_id": "$(json_escape "$PLAN_ID")",
  "plan_path": "$(json_escape "$PLAN_PATH")",
  "mode": "$(json_escape "$mode_override")",
  "ready_for_implementation": $ready,
  "blocking_decisions": $blocking_json,
  "resolved_decisions": $resolved_json,
  "created_at": "$(json_escape "$CREATED_AT")",
  "review_markdown_path": "$(json_escape "$OUTPUT_PATH")"
}
EOF

  mv "$tmp_meta" "$history_path"
  cp "$history_path" "$latest_tmp"
  mv "$latest_tmp" "$METADATA_LATEST_PATH"
  LAST_METADATA_HISTORY_PATH="$history_path"
}

cleanup_timeout_children() {
  local file="$1"
  local pid
  if [[ ! -f "$file" ]]; then
    return 0
  fi
  while IFS= read -r pid; do
    if [[ ! "$pid" =~ ^[0-9]+$ ]]; then
      continue
    fi
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -TERM "$pid" >/dev/null 2>&1 || true
    fi
  done < "$file"
  sleep 5
  while IFS= read -r pid; do
    if [[ ! "$pid" =~ ^[0-9]+$ ]]; then
      continue
    fi
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -KILL "$pid" >/dev/null 2>&1 || true
    fi
  done < "$file"
}

run_with_timeout_checked() {
  local timeout_seconds="$1"
  shift
  local -a cmd=("$@")
  local child_file
  local wrapper_pid
  local rc
  child_file="$(mktemp)"

  timeout -k5s "${timeout_seconds}s" "${cmd[@]}" &
  wrapper_pid=$!

  while kill -0 "$wrapper_pid" >/dev/null 2>&1; do
    pgrep -P "$wrapper_pid" >> "$child_file" 2>/dev/null || true
    sleep 0.1
  done

  set +e
  wait "$wrapper_pid"
  rc=$?
  set -e

  sort -u -o "$child_file" "$child_file" 2>/dev/null || true
  if [[ "$rc" == "124" || "$rc" == "137" ]]; then
    cleanup_timeout_children "$child_file"
  fi
  rm -f "$child_file"
  return "$rc"
}

run_codex_prompt() {
  local prompt="$1"
  local timeout_seconds="${2:-0}"
  local -a cmd=(codex exec --sandbox read-only --ephemeral)
  local output_file
  local start_ts
  local now_ts
  local elapsed
  local last_ping=0
  local rc
  local run_label
  local run_id
  if [[ -n "$MODEL" ]]; then
    cmd+=(--model "$MODEL")
  fi
  cmd+=(-- "$prompt")

  run_id="$(date +%s)-$$-${RANDOM}"
  run_label="run=${run_id}"
  if [[ "$MODE" == "live" ]]; then
    run_label="$run_label mode=live"
  else
    run_label="$run_label mode=$MODE"
  fi
  output_file="$(mktemp)"
  start_ts="$(date +%s)"
  emit_run_event "start" "phase=plan-review-codex $run_label timeout=${timeout_seconds}s"

  (
    cd "$REPO_PATH"
    if (( timeout_seconds > 0 )); then
      if ! command -v timeout >/dev/null 2>&1; then
        echo "Error: timeout command is required for live mode. Install coreutils timeout." >&2
        exit 1
      fi
      run_with_timeout_checked "$timeout_seconds" "${cmd[@]}"
    else
      "${cmd[@]}"
    fi
  ) > "$output_file" &
  CURRENT_CHILD_PID=$!

  while kill -0 "$CURRENT_CHILD_PID" >/dev/null 2>&1; do
    now_ts="$(date +%s)"
    elapsed=$((now_ts - start_ts))
    if (( elapsed >= LONG_RUN_THRESHOLD_SECONDS )); then
      if (( last_ping == 0 || now_ts - last_ping >= STATUS_PING_SECONDS )); then
        emit_run_event "heartbeat" "phase=plan-review-codex $run_label elapsed=${elapsed}s"
        last_ping="$now_ts"
      fi
    fi
    sleep 1
  done

  set +e
  wait "$CURRENT_CHILD_PID"
  rc=$?
  set -e
  CURRENT_CHILD_PID=""
  cat "$output_file"
  rm -f "$output_file"

  now_ts="$(date +%s)"
  elapsed=$((now_ts - start_ts))
  if [[ "$rc" == "0" ]]; then
    emit_run_event "done" "phase=plan-review-codex $run_label elapsed=${elapsed}s"
  elif [[ "$rc" == "130" || "$rc" == "143" || "$rc" == "124" || "$rc" == "137" ]]; then
    emit_run_event "interrupted" "phase=plan-review-codex $run_label exit_code=$rc elapsed=${elapsed}s"
  else
    emit_run_event "failed" "phase=plan-review-codex $run_label exit_code=$rc elapsed=${elapsed}s"
  fi
  return "$rc"
}

build_live_plan_context() {
  local context_file="$1"
  {
    echo "PLAN CONTEXT (shared across sections):"
    echo "- Plan ID: $PLAN_ID"
    echo "- Plan path: $PLAN_PATH"
    echo "- Base branch: $BASE_BRANCH"
    echo "- Current branch: $CURRENT_BRANCH"
    echo "- Head SHA: $HEAD_SHA"
    echo
    echo "Plan headings:"
    grep -E '^## ' "$PLAN_PATH" || true
    echo
    echo "Plan excerpt (first 160 lines):"
    sed -n '1,160p' "$PLAN_PATH"
  } > "$context_file"
}

if [[ "$MODE" == "batch" ]]; then
  emit_run_event "start" "phase=plan-review mode=batch plan_id=$PLAN_ID repo=$REPO_PATH"
  cat "$SYSTEM_PROMPT_FILE" > "$SYSTEM_PROMPT"
  cat >> "$SYSTEM_PROMPT" <<EOF

TASK CONTEXT:
- Repository: $REPO_PATH
- Base branch: $BASE_BRANCH
- Current branch: $CURRENT_BRANCH
- Head SHA: $HEAD_SHA
- Plan file: $PLAN_PATH

REVIEW MODE: batch
- Single non-interactive Codex exec call.
- Do not pause for AskUserQuestion.
- Assume user selected BIG CHANGE in Step 0.
- Produce full review in one response covering Architecture, Code Quality, Test, and Performance.
- Include option recommendations and unresolved decisions inline.

PLAN CONTENT:
$(cat "$PLAN_PATH")
EOF

  run_codex_prompt "$(cat "$SYSTEM_PROMPT")" | tee "$TMP_OUTPUT"
  if has_resolution_inputs; then
    load_resolution_inputs
    dedupe_file "$BLOCKING_FILE"
    if [[ -s "$BLOCKING_FILE" ]]; then
      write_metadata "false"
    else
      write_metadata "true"
    fi
  else
    printf '%s\n' "Run ./scripts/plan-review-live to resolve interactive decisions" >> "$BLOCKING_FILE"
    write_metadata "false"
  fi
elif [[ "$MODE" == "apply" ]]; then
  emit_run_event "start" "phase=plan-review mode=apply plan_id=$PLAN_ID repo=$REPO_PATH"
  if ! has_resolution_inputs; then
    emit_run_event "failed" "phase=plan-review mode=apply plan_id=$PLAN_ID reason=missing_resolution_inputs repo=$REPO_PATH"
    echo "Error: apply mode requires --resolve-file or --decisions/--blocking." >&2
    resolution_usage_hint
    exit 1
  fi
  load_resolution_inputs
  {
    echo "# Plan Review (Applied Decisions)"
    echo
    echo "- Plan: $PLAN_PATH"
    echo "- Mode: apply"
    echo "- Applied at: $CREATED_AT"
    echo
  } > "$TMP_OUTPUT"
  dedupe_file "$BLOCKING_FILE"
  if [[ -s "$BLOCKING_FILE" ]]; then
    write_metadata "false" "live"
  else
    write_metadata "true" "live"
  fi
else
  emit_run_event "start" "phase=plan-review mode=live plan_id=$PLAN_ID repo=$REPO_PATH"
  non_tty=0
  auto_applied_non_tty=0
  if [[ ! -t 0 || ! -t 1 ]]; then
    non_tty=1
  fi

  if (( non_tty == 1 )); then
    if has_resolution_inputs; then
      auto_applied_non_tty=1
      load_resolution_inputs
      {
        echo "# Plan Review (Live Auto-Fallback)"
        echo
        echo "- Plan: $PLAN_PATH"
        echo "- Mode: live (non-tty auto-apply)"
        echo "- Applied at: $CREATED_AT"
        echo
      } > "$TMP_OUTPUT"
      dedupe_file "$BLOCKING_FILE"
      if [[ -s "$BLOCKING_FILE" ]]; then
        write_metadata "false"
      else
        write_metadata "true"
      fi
    elif [[ "$ALLOW_NON_TTY" == "1" ]]; then
      echo "Warning: PLAN_REVIEW_LIVE_ALLOW_NON_TTY=1 set; bypassing TTY requirement for live mode." >&2
    elif [[ "$NON_TTY_MODE" == "error" ]]; then
      echo "Error: live mode requires an interactive terminal (TTY)." >&2
      resolution_usage_hint
      exit 1
    else
      echo "Error: non-TTY live mode requires decision input. Use --resolve-file or --decisions/--blocking." >&2
      resolution_usage_hint
      exit 1
    fi
  fi

  if (( auto_applied_non_tty == 0 )) && (( non_tty == 0 || ALLOW_NON_TTY == 1 )); then
    START_TS="$(date +%s)"
    PLAN_CONTEXT_FILE="$TMP_DIR/plan-context.txt"
    build_live_plan_context "$PLAN_CONTEXT_FILE"

    cat > "$TMP_OUTPUT" <<EOF
# Plan Review (Live)

- Plan: $PLAN_PATH
- Mode: live
- Started at: $CREATED_AT

EOF
    cp "$TMP_OUTPUT" "$OUTPUT_PATH"
    printf '%s\n' "$LIVE_INCOMPLETE_MARKER" >> "$BLOCKING_FILE"
    write_metadata "false"

    section_names=(
      "Architecture"
      "Code Quality"
      "Tests"
      "Performance"
    )

    section_instructions=(
      "Run only Architecture review. Identify up to 4 top issues with options and explicit recommendation. End by asking for decision labels."
      "Run only Code Quality review. Identify up to 4 top issues with options and explicit recommendation. End by asking for decision labels."
      "Run only Test review. Include ASCII test diagram and coverage/eval gaps. End by asking for decision labels."
      "Run only Performance review. Identify up to 4 top issues with options and explicit recommendation. End by asking for decision labels."
    )

    for idx in "${!section_names[@]}"; do
      now_ts="$(date +%s)"
      elapsed=$((now_ts - START_TS))
      remaining=$((TOTAL_TIMEOUT - elapsed))
      if (( remaining <= 0 )); then
        echo "Error: live review exceeded total timeout budget (${TOTAL_TIMEOUT}s)." >&2
        exit 1
      fi
      effective_timeout="$SECTION_TIMEOUT"
      if (( remaining < SECTION_TIMEOUT )); then
        effective_timeout="$remaining"
      fi

      section_name="${section_names[$idx]}"
      section_instruction="${section_instructions[$idx]}"

      cat "$SYSTEM_PROMPT_FILE" > "$SYSTEM_PROMPT"
      cat >> "$SYSTEM_PROMPT" <<EOF

TASK CONTEXT:
- Repository: $REPO_PATH
- Base branch: $BASE_BRANCH
- Current branch: $CURRENT_BRANCH
- Head SHA: $HEAD_SHA
- Plan file: $PLAN_PATH

REVIEW MODE: live
LIVE REVIEW SECTION: $section_name
- This is one checkpoint in a multi-step interactive review.
- Review only the named section and do not continue to other sections.
- Keep decisions explicit and label options so user can select quickly.

SECTION-SPECIFIC INSTRUCTIONS:
$section_instruction

SHARED PLAN CONTEXT:
$(cat "$PLAN_CONTEXT_FILE")
EOF

      section_output="$(run_codex_prompt "$(cat "$SYSTEM_PROMPT")" "$effective_timeout")"
      {
        echo
        echo "## $section_name"
        echo
        echo "$section_output"
        echo
      } >> "$TMP_OUTPUT"

      echo "[$section_name] Enter selected decision labels (comma-separated, or none):" >&2
      read -r selected_input
      append_list_entries "$selected_input" "$RESOLVED_FILE"

      echo "[$section_name] Enter unresolved blocking decision IDs/descriptions (comma-separated, or none):" >&2
      read -r blocking_input
      append_list_entries "$blocking_input" "$BLOCKING_FILE"
    done

    tmp_filtered="$(mktemp)"
    grep -Fxv "$LIVE_INCOMPLETE_MARKER" "$BLOCKING_FILE" > "$tmp_filtered" || true
    mv "$tmp_filtered" "$BLOCKING_FILE"
    dedupe_file "$BLOCKING_FILE"
    if [[ -s "$BLOCKING_FILE" ]]; then
      write_metadata "false"
    else
      write_metadata "true"
    fi
  fi
fi

mv "$TMP_OUTPUT" "$OUTPUT_PATH"

emit_run_event "done" "phase=plan-review mode=$MODE plan_id=$PLAN_ID output=$OUTPUT_PATH"
echo
echo "✅ Plan review saved: $OUTPUT_PATH"
echo "✅ Plan review metadata (history): $LAST_METADATA_HISTORY_PATH"
echo "✅ Plan review metadata (latest): $METADATA_LATEST_PATH"
