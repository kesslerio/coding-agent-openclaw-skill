#!/usr/bin/env bash
# tmux-run - Run a command inside tmux with logging and monitoring hints
# Usage: tmux-run [--wait] [--cleanup] [--output text|json] <command...>
set -euo pipefail

export PATH="$PATH:/run/current-system/sw/bin"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/wrapper-io.sh"

COMMAND_NAME="tmux-run"

usage() {
  cat >&2 <<EOF2
Usage: tmux-run [--wait] [--cleanup] [--output text|json] <command...>

Options:
  --wait        Block until the command finishes (signals via tmux wait-for)
  --cleanup     Kill the tmux session after completion (implies --wait)
  --output      Response format for transport metadata (default: text)

Environment:
  CODEX_TMUX_WAIT=1         Same as --wait
  CODEX_TMUX_CLEANUP=1      Same as --cleanup
  CODEX_TMUX_WAIT_TIMEOUT=  Optional seconds to bound --wait
EOF2
}

WAIT="${CODEX_TMUX_WAIT:-0}"
CLEANUP="${CODEX_TMUX_CLEANUP:-0}"
HEARTBEAT_SECONDS="${CODEX_TMUX_HEARTBEAT_SECONDS:-20}"
HEARTBEAT_MIN_ELAPSED_SECONDS="${CODEX_TMUX_HEARTBEAT_MIN_ELAPSED_SECONDS:-30}"
CAPTURE_LINES="${CODEX_TMUX_CAPTURE_LINES:-400}"
EVENT_TOKEN="${CODEX_TMUX_EVENT_TOKEN:-}"
OUTPUT_MODE="text"
RUN_ID="$(generate_run_id)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --wait)
      WAIT=1
      shift
      ;;
    --cleanup)
      CLEANUP=1
      shift
      ;;
    --output)
      OUTPUT_MODE="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [[ "$CLEANUP" == "1" && "$WAIT" != "1" ]]; then
  WAIT=1
fi

if ! ensure_output_mode "$OUTPUT_MODE"; then
  usage
  exit 1
fi

require_cmd_or_die "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "jq" \
  "Install jq before using tmux-run."

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

if [[ ! "$HEARTBEAT_SECONDS" =~ ^[0-9]+$ ]] || (( HEARTBEAT_SECONDS <= 0 )); then
  echo "Error: CODEX_TMUX_HEARTBEAT_SECONDS must be a positive integer" >&2
  exit 1
fi

if [[ ! "$HEARTBEAT_MIN_ELAPSED_SECONDS" =~ ^[0-9]+$ ]] || (( HEARTBEAT_MIN_ELAPSED_SECONDS < 0 )); then
  echo "Error: CODEX_TMUX_HEARTBEAT_MIN_ELAPSED_SECONDS must be a non-negative integer" >&2
  exit 1
fi

if [[ ! "$CAPTURE_LINES" =~ ^[0-9]+$ ]] || (( CAPTURE_LINES <= 0 )); then
  echo "Error: CODEX_TMUX_CAPTURE_LINES must be a positive integer" >&2
  exit 1
fi

wait_timeout="${CODEX_TMUX_WAIT_TIMEOUT:-}"
if [[ "$WAIT" == "1" && -n "$wait_timeout" ]]; then
  if [[ ! "$wait_timeout" =~ ^[0-9]+$ ]] || (( wait_timeout <= 0 )); then
    echo "Error: CODEX_TMUX_WAIT_TIMEOUT must be a positive integer" >&2
    exit 1
  fi
fi

emit_tmux_run_event() {
  local event="$1"
  local details="${2:-}"
  local token_details=""
  if [[ -n "$EVENT_TOKEN" ]]; then
    token_details=" token=$EVENT_TOKEN"
  fi
  if [[ -n "$details" ]]; then
    echo "TMUX_RUN_EVENT $event ts=$(date -Iseconds)${token_details} $details" >&2
  else
    echo "TMUX_RUN_EVENT $event ts=$(date -Iseconds)${token_details}" >&2
  fi
}

if ! command -v tmux >/dev/null 2>&1; then
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_MISSING" \
    "tmux not found in PATH." \
    "{}" \
    "null" \
    "Install tmux before using tmux-run."
  exit 1
fi

SOCKET_DIR="${CODEX_TMUX_SOCKET_DIR:-${OPENCLAW_TMUX_SOCKET_DIR:-${CLAWDBOT_TMUX_SOCKET_DIR:-${TMPDIR:-/tmp}/openclaw-tmux-sockets}}}"
mkdir -p "$SOCKET_DIR"
SOCKET="${CODEX_TMUX_SOCKET:-$SOCKET_DIR/openclaw.sock}"

SESSION_PREFIX="${CODEX_TMUX_SESSION_PREFIX:-codex}"
ts="$(date +%Y%m%d-%H%M%S)"
ns="$(date +%N 2>/dev/null || true)"
if [[ "$ns" =~ ^[0-9]+$ ]]; then
  ts="${ts}-${ns}"
fi
SESSION="${CODEX_TMUX_SESSION:-${SESSION_PREFIX}-${ts}-${RANDOM}-$$}"

LOG_DIR="${CODEX_TMUX_LOG_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/openclaw/tmux}"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/${SESSION}.log"
: > "$LOG_FILE"
EXIT_FILE="$LOG_DIR/${SESSION}.exit"
rm -f "$EXIT_FILE"

if ! tmux -S "$SOCKET" new-session -d -s "$SESSION" -n shell; then
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_SESSION_START_FAILED" \
    "Failed to create tmux session." \
    "$(jq -n --arg socket "$SOCKET" '{socket: $socket}')" \
    "null" \
    "Verify tmux is installed and the socket path is writable."
  exit 1
fi
tmux -S "$SOCKET" set-option -t "$SESSION" remain-on-exit on

FIRST_WINDOW="$(tmux -S "$SOCKET" list-windows -t "$SESSION" -F '#{window_index}' 2>/dev/null | head -n 1 || true)"
if [[ -z "$FIRST_WINDOW" ]]; then
  tmux -S "$SOCKET" kill-session -t "$SESSION" || true
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_WINDOW_RESOLUTION_FAILED" \
    "Failed to resolve tmux window index for the new session." \
    "$(jq -n --arg session "$SESSION" '{session: $session}')" \
    "null" \
    "Retry the launch after confirming tmux can create windows normally."
  exit 1
fi

FIRST_PANE="$(tmux -S "$SOCKET" list-panes -t "${SESSION}:${FIRST_WINDOW}" -F '#{pane_index}' 2>/dev/null | head -n 1 || true)"
if [[ -z "$FIRST_PANE" ]]; then
  tmux -S "$SOCKET" kill-session -t "$SESSION" || true
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_PANE_RESOLUTION_FAILED" \
    "Failed to resolve tmux pane index for the new session." \
    "$(jq -n --arg session "$SESSION" '{session: $session}')" \
    "null" \
    "Retry the launch after confirming tmux can create panes normally."
  exit 1
fi

TARGET="${SESSION}:${FIRST_WINDOW}.${FIRST_PANE}"

if ! tmux -S "$SOCKET" pipe-pane -t "$TARGET" -o "cat >> \"$LOG_FILE\""; then
  tmux -S "$SOCKET" kill-session -t "$SESSION" || true
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_PIPE_ATTACH_FAILED" \
    "Failed to attach tmux pipe-pane logging." \
    "$(jq -n --arg target "$TARGET" --arg log_file "$LOG_FILE" '{target: $target, log_file: $log_file}')" \
    "null" \
    "Retry the launch after confirming the log directory is writable."
  exit 1
fi

cmd_str=$(printf '%q ' "$@")
cmd_str="${cmd_str% }"
if [[ "$WAIT" == "1" ]]; then
  cmd_str="$cmd_str; __tmux_run_rc=\$?; printf '%s\n' \"\${__tmux_run_rc}\" > \"$EXIT_FILE\"; tmux -S \"$SOCKET\" wait-for -S \"$SESSION.done\""
fi
if ! tmux -S "$SOCKET" send-keys -t "$TARGET" -l -- "$cmd_str"; then
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_LAUNCH_DISPATCH_FAILED" \
    "Failed to send command text to the tmux session." \
    "$(jq -n --arg target "$TARGET" '{target: $target}')" \
    "null" \
    "Retry the launch after confirming the tmux session is still running."
  exit 1
fi
if ! tmux -S "$SOCKET" send-keys -t "$TARGET" Enter; then
  emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_LAUNCH_DISPATCH_FAILED" \
    "Failed to send Enter to the tmux session." \
    "$(jq -n --arg target "$TARGET" '{target: $target}')" \
    "null" \
    "Retry the launch after confirming the tmux session is still running."
  exit 1
fi

metadata_json="$(jq -n \
  --arg session "$SESSION" \
  --arg socket "$SOCKET" \
  --arg log_file "$LOG_FILE" \
  --arg target "$TARGET" \
  --arg mode "$([[ "$WAIT" == "1" ]] && printf 'blocking' || printf 'non-blocking')" \
  '{
    session: $session,
    socket: $socket,
    log_file: $log_file,
    target: $target,
    mode: $mode
  }')"

if [[ "$OUTPUT_MODE" == "text" ]]; then
  cat >&2 <<EOF2
tmux session started.
Socket: $SOCKET
Session: $SESSION
Log: $LOG_FILE
Mode: $([[ "$WAIT" == "1" ]] && echo "blocking (--wait)" || echo "non-blocking")
To monitor:
  tmux -S "$SOCKET" attach -t "$SESSION"
  tmux -S "$SOCKET" capture-pane -p -J -t "$TARGET" -S -200
  tail -f "$LOG_FILE"
EOF2
fi

mode_label="nowait"
if [[ "$WAIT" == "1" ]]; then
  mode_label="wait"
fi
emit_tmux_run_event "start" "session=$SESSION log_path=$LOG_FILE socket=$SOCKET mode=$mode_label"

if [[ "$WAIT" == "1" ]]; then
  start_ts="$(date +%s)"
  last_heartbeat="$start_ts"
  timed_out=0
  lost_session=0
  exit_ready=0
  rc=1

  while true; do
    if [[ -f "$EXIT_FILE" ]]; then
      rc_candidate="$(cat "$EXIT_FILE" 2>/dev/null || true)"
      if [[ "$rc_candidate" =~ ^[0-9]+$ ]]; then
        rc="$rc_candidate"
        exit_ready=1
        break
      fi
    fi

    if ! tmux -S "$SOCKET" has-session -t "$SESSION" >/dev/null 2>&1; then
      echo "Warning: tmux session disappeared before exit status was recorded" >&2
      lost_session=1
      break
    fi

    now_ts="$(date +%s)"
    elapsed=$((now_ts - start_ts))
    if (( elapsed >= HEARTBEAT_MIN_ELAPSED_SECONDS && now_ts - last_heartbeat >= HEARTBEAT_SECONDS )); then
      emit_tmux_run_event "heartbeat" "session=$SESSION elapsed_s=${elapsed}"
      last_heartbeat="$now_ts"
    fi

    if [[ -n "$wait_timeout" && "$elapsed" -ge "$wait_timeout" ]]; then
      echo "Warning: wait timed out after ${wait_timeout}s" >&2
      timed_out=1
      break
    fi
    sleep 1
  done

  if (( timed_out == 1 )); then
    rc=124
  elif (( lost_session == 1 )); then
    rc=1
  elif (( exit_ready != 1 )); then
    echo "Warning: Exit code file not ready: $EXIT_FILE" >&2
    rc=1
  fi

  elapsed_total=$(( $(date +%s) - start_ts ))
  if [[ "$rc" == "0" ]]; then
    emit_tmux_run_event "done" "session=$SESSION exit_code=$rc elapsed_s=${elapsed_total}"
  elif [[ "$rc" == "124" || "$rc" == "130" || "$rc" == "137" || "$rc" == "143" ]]; then
    emit_tmux_run_event "interrupted" "session=$SESSION exit_code=$rc elapsed_s=${elapsed_total}"
  else
    emit_tmux_run_event "failed" "session=$SESSION exit_code=$rc elapsed_s=${elapsed_total}"
  fi

  if [[ "$CLEANUP" == "1" ]]; then
    tmux -S "$SOCKET" kill-session -t "$SESSION" || true
  fi

  if (( timed_out == 1 )) && [[ "$OUTPUT_MODE" == "json" ]]; then
    emit_error "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "TMUX_WAIT_TIMEOUT" \
      "Timed out while waiting for the tmux session to signal completion." \
      "$(jq -n --arg session "$SESSION" '{session: $session}')" \
      "null" \
      "Inspect the tmux session and logs, then retry."
    exit "$rc"
  fi

  if [[ "$OUTPUT_MODE" == "json" ]]; then
    emit_success "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" \
      "$(jq -n \
        --argjson metadata "$metadata_json" \
        --arg exit_code "$rc" \
        '{
          session: $metadata.session,
          socket: $metadata.socket,
          log_file: $metadata.log_file,
          target: $metadata.target,
          mode: $metadata.mode,
          exit_code: ($exit_code | tonumber)
        }')"
    exit "$rc"
  fi

  tmux -S "$SOCKET" capture-pane -p -J -t "$TARGET" -S "-${CAPTURE_LINES}" 2>/dev/null || true
  exit "$rc"
fi

emit_success "$OUTPUT_MODE" "$COMMAND_NAME" "$RUN_ID" "$metadata_json"
